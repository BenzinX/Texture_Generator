{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "procedural-pbr",
  "version-string": "1.0.0",
  "description": "PBR Procedural Texture Generator (GLFW + GLAD + ImGui)",
  "dependencies": [
    "glfw3",
    "glad",
    {
      "name": "imgui",
      "features": [
        "glfw-binding",
        "opengl3-binding"
      ]
    }
  ],
  "builtin-baseline": "latest"
}
